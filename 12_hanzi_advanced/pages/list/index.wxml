<view class="container">
  <view class="page-header">
    <text class="page-title">三年级</text>
    <text class="page-subtitle">598字 · 义务教育阶段</text>
  </view>

  <view class="progress-section">
    <view class="progress-bar"><view class="progress-fill" style="width: {{totalCount > 0 ? (learnedCount / totalCount) * 100 : 0}}%"></view></view>
    <text class="progress-text">{{learnedCount}}/{{totalCount}} 已学</text>
  </view>

  <view class="char-grid" wx:if="{{characters.length > 0}}">
    <view class="char-card {{item.learned ? 'learned' : ''}}" wx:for="{{characters}}" wx:key="char"
          bindtap="goToPractice" data-char="{{item.char}}">
      <text class="char-pinyin">{{item.pinyin}}</text>
      <text class="char-display">{{item.char}}</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{characters.length === 0}}">
    <text class="empty-text">暂无汉字数据</text>
  </view>
</view>
