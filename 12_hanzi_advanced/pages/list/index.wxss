/* 汉字列表页面样式 - 优化版 */

.container {
  min-height: 100vh;
  background: #f7f4ef;
  padding: 0 16px 48px;
}

/* ========== 页面头部 ========== */
.page-header {
  padding: 32px 8px 4px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.page-title {
  font-size: 26px;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 1px;
}

.page-subtitle {
  font-size: 13px;
  color: #bbb0a0;
  font-weight: 400;
}

/* ========== 分类标签 ========== */
.category-scroll {
  white-space: nowrap;
  padding: 12px 0 16px;
}

.category-tag {
  display: inline-block;
  padding: 7px 20px;
  margin-right: 10px;
  font-size: 13px;
  color: #8b8274;
  background: #fff;
  border-radius: 18px;
  border: 1px solid #e8e3d8;
  transition: all 0.2s ease;
}

.category-tag:active {
  transform: scale(0.95);
}

.category-tag.active {
  color: #fff;
  background: #c0392b;
  border-color: #c0392b;
  box-shadow: 0 2px 8px rgba(192, 57, 43, 0.2);
}

/* ========== 进度条 ========== */
.progress-section {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 22px;
  padding: 0 4px;
}

.progress-bar {
  flex: 1;
  height: 8px;
  background: #e8e3d8;
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c0392b, #e35d4a);
  border-radius: 4px;
  transition: width 0.4s ease;
}

.progress-text {
  font-size: 13px;
  color: #a09688;
  font-weight: 500;
  min-width: 52px;
  text-align: right;
}

/* ========== 字卡网格 ========== */
.char-grid {
  display: flex;
  flex-wrap: wrap;
}

.char-card {
  width: 16.66%;
  padding: 8px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: background 0.15s ease;
}

.char-card:active {
  background: #ede8e0;
}

/* 已学卡片的标记色 */
.char-card.learned {
  background: transparent;
}

/* 拼音 */
.char-pinyin {
  font-size: 9px;
  color: #ccc4b8;
  font-weight: 500;
  line-height: 1;
  margin-bottom: 1px;
}

/* 主汉字 */
.char-display {
  font-size: 26px;
  font-weight: 550;
  color: #3a3a3a;
  line-height: 1.3;
  font-family: "STKaiti", "KaiTi", "楷体", "PingFang SC", serif;
}

.learned .char-display {
  color: #c5bdb0;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80px 0;
}

.empty-state.placeholder {
  flex-direction: column;
  gap: 12px;
  padding: 100px 0;
}

.empty-icon {
  font-size: 40px;
}

.empty-text {
  font-size: 14px;
  color: #ccc;
}
