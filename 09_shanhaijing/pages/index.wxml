<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-title" wx:if="{{contentId && currentTitle !== book.title}}">{{currentTitle}}</view>
    <view class="nav-menu-btn" bindtap="toggleMenu">
      <view class="menu-icon">
        <view class="menu-icon-line"></view>
        <view class="menu-icon-line"></view>
        <view class="menu-icon-line"></view>
      </view>
    </view>
  </view>

  <!-- 遮罩层 -->
  <view class="menu-overlay {{showMenu ? 'show' : ''}}" catchtap="closeMenu"></view>

  <!-- 底部弹窗菜单 -->
  <view class="bottom-sheet {{showMenu ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-header">
      <text class="sheet-title">📖 章节目录</text>
      <view class="sheet-close" bindtap="closeMenu">
        <text class="sheet-close-x">✕</text>
      </view>
    </view>
    <scroll-view class="sheet-body" scroll-y>
      <view wx:for="{{menuList}}" wx:key="id" class="sheet-group" wx:for-item="group">
        <block wx:if="{{group.children && group.children.length > 0}}">
          <view class="sheet-group-title">{{group.title}}</view>
          <view wx:for="{{group.children}}" wx:key="id" wx:for-item="ch"
                class="sheet-item {{contentId === ch.id ? 'active' : ''}}"
                catchtap="selectMenuItem" data-id="{{ch.id}}">
            <text class="sheet-item-text">{{ch.title}}</text>
            <text class="sheet-item-check" wx:if="{{contentId === ch.id}}">✓</text>
          </view>
        </block>
        <view wx:else
              class="sheet-item {{contentId === group.id ? 'active' : ''}}"
              catchtap="selectMenuItem" data-id="{{group.id}}">
          <text class="sheet-item-text">{{group.title}}</text>
          <text class="sheet-item-check" wx:if="{{contentId === group.id}}">✓</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 内容区 -->
  <view class="content">
    <view class="content-inner">
      <!-- 卡片模式 -->
      <view wx:if="{{contentType === 'cards'}}" class="card-full">
        <view class="card-page-header">
          <text class="card-page-title">{{pageTitle}}</text>
          <text class="card-page-subtitle" wx:if="{{pageSubtitle}}">{{pageSubtitle}}</text>
          <text class="card-page-desc" wx:if="{{pageDesc}}">{{pageDesc}}</text>
        </view>
        <view class="card-grid">
          <view wx:for="{{beasts}}" wx:key="name" class="card-wrapper" catchtap="flipCard" data-index="{{index}}">
            <view class="card-inner {{item.flipped ? 'flipped' : ''}}">
              <view class="card-face card-front">
                <view wx:if="{{item.image}}" class="card-img-wrap">
                  <image class="card-image" src="{{item.image}}" mode="aspectFill"></image>
                </view>
                <view wx:else class="card-no-image">
                  <text class="card-no-image-text">{{item.appearance}}</text>
                </view>
                <view class="card-name-tag">{{item.name}}</view>
              </view>
              <view class="card-face card-back">
                <view class="card-back-header">{{item.name}}</view>
                <view class="card-back-section">
                  <text class="card-back-label">【山海经原文】</text>
                  <text class="card-back-text">{{item.original}}</text>
                </view>
                <view class="card-back-section">
                  <text class="card-back-label">【释义】</text>
                  <text class="card-back-text">{{item.translation}}</text>
                </view>
                <view class="card-tip">点击翻转</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- Markdown 模式 -->
      <view wx:else class="markdown-full">
        <towxml nodes="{{article}}"/>
      </view>
    </view>
  </view>
</view>
