.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

/* ============ 顶部导航栏 ============ */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  z-index: 50;
  box-sizing: border-box;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 20rpx;
}

/* 汉堡图标 */
.nav-menu-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.nav-menu-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
}

.menu-icon-line {
  width: 100%;
  height: 3rpx;
  background: #555;
  border-radius: 2rpx;
}

/* ============ 遮罩层 ============ */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 90;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.menu-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* ============ 底部弹窗 ============ */
.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 75vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 95;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.bottom-sheet.show {
  transform: translateY(0);
}

/* 拖拽指示条 */
.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  margin: 16rpx auto 8rpx;
  flex-shrink: 0;
}

/* 弹窗头部 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.sheet-close:active {
  background: #e8e8e8;
}

.sheet-close-x {
  font-size: 28rpx;
  color: #999;
}

/* 弹窗内容（可滚动） */
.sheet-body {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 32rpx 40rpx;
}

/* 分组标题 */
.sheet-group {
  margin-bottom: 20rpx;
}

.sheet-group:last-child {
  margin-bottom: 0;
}

.sheet-group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #95a5a6;
  padding: 16rpx 0 8rpx;
  letter-spacing: 2rpx;
}

/* 章节项 */
.sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.sheet-item:active {
  background: #f5f0eb;
}

.sheet-item.active {
  background: #fdf6ec;
}

.sheet-item-text {
  font-size: 28rpx;
  color: #333;
}

.sheet-item.active .sheet-item-text {
  color: #c0392b;
  font-weight: 600;
}

.sheet-item-check {
  font-size: 28rpx;
  color: #c0392b;
  font-weight: 700;
}

/* ============ 内容区 ============ */
.content {
  flex: 1;
  height: 100vh;
  overflow-y: auto;
  background: #f9f9f9;
  padding-top: 88rpx;
}

.content-inner {
  padding: 32rpx 28rpx 60rpx;
}

/* ============ 卡片模式 ============ */

/* 页面头部 */
.card-page-header {
  margin-bottom: 32rpx;
  text-align: center;
}
.card-page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2c3e50;
  display: block;
}
.card-page-subtitle {
  font-size: 28rpx;
  color: #7f8c8d;
  margin-top: 12rpx;
  display: block;
}
.card-page-desc {
  font-size: 26rpx;
  color: #95a5a6;
  margin-top: 16rpx;
  display: block;
  line-height: 1.6;
}

/* 卡片网格 */
.card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

/* 卡片容器 */
.card-wrapper {
  height: 480rpx;
  perspective: 1500rpx;
  cursor: pointer;
}

/* 卡片内部 — 3D 翻转 */
.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

/* 卡片的两个面 */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-sizing: border-box;
}

/* 正面 */
.card-front {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #fefefe, #f5f0eb);
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-img-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 无图片时的占位 */
.card-no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 36rpx;
  background: linear-gradient(135deg, #fdfcfb 0%, #e2d1c3 100%);
}

.card-no-image-text {
  font-size: 24rpx;
  color: #7f5f4e;
  line-height: 1.8;
  text-align: center;
  font-style: italic;
}

/* 名字标签 */
.card-name-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 4rpx;
}

/* 反面 */
.card-back {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  background: #2c3e50;
  color: #ecf0f1;
  transform: rotateY(180deg);
  overflow-y: auto;
}

.card-back-header {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.2);
}

.card-back-section {
  margin-bottom: 12rpx;
}

.card-back-label {
  font-size: 20rpx;
  color: #f1c40f;
  font-weight: bold;
  display: block;
  margin-bottom: 4rpx;
}

.card-back-text {
  font-size: 22rpx;
  color: #bdc3c7;
  line-height: 1.7;
  display: block;
}

.card-tip {
  margin-top: auto;
  text-align: center;
  font-size: 18rpx;
  color: #7f8c8d;
  padding-top: 8rpx;
}

/* ============ 移动端适配 ============ */
@media screen and (max-width: 768px) {
  .card-grid {
    grid-template-columns: repeat(1, 1fr);
  }
  .card-wrapper {
    height: 440rpx;
  }
  .content-inner {
    padding: 24rpx 20rpx 40rpx;
  }
}
