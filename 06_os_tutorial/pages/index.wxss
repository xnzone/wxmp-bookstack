.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

/* ============ 顶部导航栏 ============ */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  z-index: 50;
  box-sizing: border-box;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 20rpx;
}

.nav-menu-btn {
  margin-left: auto;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.nav-menu-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
}

.menu-icon-line {
  width: 100%;
  height: 3rpx;
  background: #555;
  border-radius: 2rpx;
}

/* ============ 遮罩层 ============ */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 90;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.menu-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* ============ 底部弹窗 ============ */
.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 75vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 95;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.bottom-sheet.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  margin: 16rpx auto 8rpx;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.sheet-close:active {
  background: #e8e8e8;
}

.sheet-close-x {
  font-size: 28rpx;
  color: #999;
}

.sheet-body {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 32rpx 40rpx;
}

.sheet-group {
  margin-bottom: 20rpx;
}

.sheet-group:last-child {
  margin-bottom: 0;
}

.sheet-group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #95a5a6;
  padding: 16rpx 0 8rpx;
  letter-spacing: 2rpx;
}

.sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.sheet-item:active {
  background: #f5f0eb;
}

.sheet-item.active {
  background: #fdf6ec;
}

.sheet-item-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 12rpx;
}

.sheet-item.active .sheet-item-text {
  color: #c0392b;
  font-weight: 600;
}

.sheet-item-check {
  font-size: 28rpx;
  color: #c0392b;
  font-weight: 700;
  flex-shrink: 0;
}

/* ============ 内容区 ============ */
.content {
  flex: 1;
  height: 100vh;
  overflow-y: auto;
  background: #f9f9f9;
  padding-top: 88rpx;
}

.content-inner {
  padding: 32rpx 28rpx 60rpx;
}
