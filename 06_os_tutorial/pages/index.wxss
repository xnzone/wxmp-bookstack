.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

/* ============ 顶部导航栏 ============ */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  z-index: 50;
  box-sizing: border-box;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 20rpx;
}

.nav-menu-btn {
  margin-left: auto;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.nav-menu-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
}

.menu-icon-line {
  width: 100%;
  height: 3rpx;
  background: #555;
  border-radius: 2rpx;
}

/* ============ 遮罩层 ============ */
.menu-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 90;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.menu-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* ============ 底部弹窗 ============ */
.bottom-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 75vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 95;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.bottom-sheet.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  margin: 16rpx auto 8rpx;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.sheet-close:active {
  background: #e8e8e8;
}

.sheet-close-x {
  font-size: 28rpx;
  color: #999;
}

.sheet-body {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 32rpx 40rpx;
}

.sheet-group {
  margin-bottom: 20rpx;
}

.sheet-group:last-child {
  margin-bottom: 0;
}

.sheet-group-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #95a5a6;
  padding: 16rpx 0 8rpx;
  letter-spacing: 2rpx;
}

.sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.sheet-item:active {
  background: #f5f0eb;
}

.sheet-item.active {
  background: #fdf6ec;
}

.sheet-item-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 12rpx;
}

.sheet-item.active .sheet-item-text {
  color: #c0392b;
  font-weight: 600;
}

.sheet-item-check {
  font-size: 28rpx;
  color: #c0392b;
  font-weight: 700;
  flex-shrink: 0;
}

/* ============ 内容区 ============ */
.content {
  flex: 1;
  height: 100vh;
  overflow-y: auto;
  background: #f9f9f9;
  padding-top: 88rpx;
}

.content-inner {
  padding: 32rpx 28rpx 60rpx;
}

/* ======================================================
   📖 Markdown 内容渲染美化（覆盖 towxml 默认样式）
   ====================================================== */

/* 正文 - 更好的阅读体验 */
.content-inner .h2w {
  font-size: 32rpx;
  line-height: 1.9;
  color: #333;
  letter-spacing: 1rpx;
  font-weight: 400;
  text-align: left;
  font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
}

.content-inner .h2w__p {
  margin: 24rpx 0;
}

/* 标题 - 更清晰的层次 */
.content-inner .h2w__h1 {
  font-size: 44rpx;
  border-bottom: 2rpx solid #e8e0d8;
  padding-bottom: 16rpx;
  margin: 48rpx 0 24rpx;
  color: #2c2c2c;
  letter-spacing: 2rpx;
  font-weight: 700;
  font-family: "PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Microsoft YaHei", sans-serif;
}

.content-inner .h2w__h2 {
  font-size: 38rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 12rpx;
  margin: 40rpx 0 20rpx;
  color: #2c2c2c;
  letter-spacing: 1.5rpx;
  font-weight: 650;
}

.content-inner .h2w__h3 {
  font-size: 34rpx;
  margin: 32rpx 0 16rpx;
  color: #3a3a3a;
  letter-spacing: 1rpx;
  font-weight: 600;
}

.content-inner .h2w__h4 {
  font-size: 32rpx;
  margin: 28rpx 0 14rpx;
  color: #4a4a4a;
  font-weight: 600;
}

/* 代码块 - 浅色主题（适配白色背景阅读器） */
.content-inner .h2w__pre {
  background: #f7f5f0;
  border: 1rpx solid #e8e3d8;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin: 28rpx 0;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-all;
  word-wrap: break-word;
  padding-top: 80rpx;
}

/* 代码块顶部指示条 */
.content-inner .h2w__pre::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #c0392b, #e67e22);
  border-radius: 16rpx 16rpx 0 0;
}

.content-inner .h2w__pre .h2w__code {
  background: transparent;
  border: none;
  color: #3a3a3a;
  font-size: 26rpx;
  line-height: 1.9;
  padding: 0;
  margin: 0;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 复制按钮 - 右上角 */
.code-lang-tag {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  padding: 8rpx 18rpx;
  min-width: 60rpx;
  text-align: center;
  background: #8b8274;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #fff;
  line-height: 1.2;
  z-index: 100;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.code-lang-tag:active {
  background: #c0392b;
}

/* 代码块顶部指示条 */
.content-inner .h2w__pre::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #c0392b, #e67e22);
  border-radius: 16rpx 16rpx 0 0;
}

.content-inner .h2w__pre .h2w__code {
  background: transparent;
  border: none;
  color: #3a3a3a;
  font-size: 26rpx;
  line-height: 1.9;
  padding: 0;
  margin: 0;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
}

/* 代码高亮 - 适配浅色背景 */
.content-inner .h2w__pre .hljs {
  background: transparent;
  padding: 0;
  color: #3a3a3a;
}

.content-inner .h2w__pre .hljs-keyword,
.content-inner .h2w__pre .hljs-selector-tag,
.content-inner .h2w__pre .hljs-built_in {
  color: #c0392b;
  font-weight: 500;
}

.content-inner .h2w__pre .hljs-string,
.content-inner .h2w__pre .hljs-meta-string {
  color: #2d7d46;
}

.content-inner .h2w__pre .hljs-number,
.content-inner .h2w__pre .hljs-literal {
  color: #b07c1a;
}

.content-inner .h2w__pre .hljs-comment,
.content-inner .h2w__pre .hljs-quote {
  color: #9a9080;
  font-style: italic;
}

.content-inner .h2w__pre .hljs-attr,
.content-inner .h2w__pre .hljs-attribute {
  color: #4a6fa5;
}

.content-inner .h2w__pre .hljs-title,
.content-inner .h2w__pre .hljs-section {
  color: #2966a3;
  font-weight: 500;
}

/* 隐藏代码行号 */
.h2w__lineNum,
.h2w__lineNumLine {
  display: none !important;
}

/* 行内代码 - 品牌色药丸 */
.content-inner .h2w__code {
  background: #fef0ec;
  border: 1rpx solid #f5d4cc;
  color: #c0392b;
  font-size: 80%;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  margin: 0 4rpx;
  font-weight: 500;
}

/* 引用块 */
.content-inner .h2w__blockquote {
  border-left: 6rpx solid #c0392b;
  background: #fdf8f4;
  padding: 20rpx 24rpx;
  margin: 28rpx 0;
  border-radius: 0 12rpx 12rpx 0;
}

.content-inner .h2w__blockquote .h2w__p {
  margin: 8rpx 0;
  color: #666;
  font-size: 30rpx;
}

/* 表格 - 现代表格 */
.content-inner .h2w__table {
  border-collapse: separate;
  border-spacing: 0;
  margin: 28rpx 0;
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  width: 100%;
  font-size: 28rpx;
}

.content-inner .h2w__th {
  background: #f5f0eb;
  color: #4a3a2a;
  font-weight: 600;
  padding: 18rpx 20rpx;
  border: none;
  font-size: 28rpx;
  text-align: left;
}

.content-inner .h2w__td {
  padding: 16rpx 20rpx;
  border: none;
  border-bottom: 1rpx solid #f0ebe4;
  font-size: 28rpx;
  color: #555;
}

.content-inner .h2w__tr:last-child .h2w__td {
  border-bottom: none;
}

.content-inner .h2w__tr:nth-child(even) .h2w__td {
  background: #faf8f5;
}

/* 列表 - 更好的间距 */
.content-inner .h2w__ul,
.content-inner .h2w__ol {
  margin: 20rpx 0;
  padding-left: 40rpx;
}

.content-inner .h2w__li {
  margin: 10rpx 0;
  font-size: 30rpx;
  line-height: 1.7;
}

/* 图片 - 圆角 + 阴影 */
.content-inner image {
  border-radius: 14rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin: 24rpx 0;
  display: block;
}

/* 分割线 - 更精致 */
.content-inner .h2w__hr {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #ddd, transparent);
  margin: 40rpx 0;
}

/* 链接 */
.content-inner .h2w__a {
  color: #c0392b;
  border-bottom: 1rpx solid rgba(192, 57, 43, 0.3);
}

/* 加粗 */
.content-inner .h2w__strong {
  font-weight: 600;
  color: #2c2c2c;
}
