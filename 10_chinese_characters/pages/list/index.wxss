/* 汉字列表页面样式 - 优化版 */

.container {
  min-height: 100vh;
  background: #f7f4ef;
  padding: 0 16px 48px;
}

/* ========== 页面头部 ========== */
.page-header {
  padding: 32px 8px 4px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.page-title {
  font-size: 26px;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 2px;
}

.page-subtitle {
  font-size: 13px;
  color: #bbb0a0;
  font-weight: 400;
  letter-spacing: 1px;
}

/* ========== 进度条 ========== */
.progress-section {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 22px;
  padding: 0 4px;
}

.progress-bar {
  flex: 1;
  height: 8px;
  background: #e8e3d8;
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #c0392b, #e35d4a);
  border-radius: 4px;
  transition: width 0.4s ease;
}

.progress-text {
  font-size: 13px;
  color: #a09688;
  font-weight: 500;
  min-width: 52px;
  text-align: right;
}

/* ========== 字卡网格 ========== */
.char-grid {
  display: flex;
  flex-wrap: wrap;
}

.char-card {
  width: 16.66%;
  padding: 8px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: background 0.15s ease;
}

.char-card:active {
  background: #ede8e0;
}

/* 已学卡片的标记色 */
.char-card.learned {
  background: transparent;
}

/* 拼音 */
.char-pinyin {
  font-size: 9px;
  color: #ccc4b8;
  font-weight: 500;
  line-height: 1;
  margin-bottom: 1px;
}

/* 主汉字 */
.char-display {
  font-size: 26px;
  font-weight: 550;
  color: #3a3a3a;
  line-height: 1.3;
  font-family: "STKaiti", "KaiTi", "楷体", "PingFang SC", serif;
}

.learned .char-display {
  color: #c5bdb0;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80px 0;
}

.empty-text {
  font-size: 14px;
  color: #ccc;
}
